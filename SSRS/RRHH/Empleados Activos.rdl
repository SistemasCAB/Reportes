  <DataSets>
    <DataSet Name="EmpleadosActivos">
      <Query>
        <DataSourceName>APS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@desde">
            <Value>=Parameters!desde.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@hasta">
            <Value>=Parameters!hasta.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>declare @fechaDesde datetime = CAST(@desde as DATE);
declare @fechaHasta datetime = DATEADD(SECOND, -1, DATEADD(DAY, 1, CAST(CAST(@hasta AS DATE) AS DATETIME)));

SELECT 
    id_employee, 
    code_national,
    Apellido_y_nombre = name_full, 
    DNI = np_char_0, 
    Tipo_Documento = np_char_1, 
    Legajo = enrollment_code, 
    Departamento = department_name, 
    Fecha_cumpleanos = date_birth,
    Fecha_inicio_religioso = date_first_hire,
    Fecha_inicio_cab = date_hired,
    Estado = CAST(status_active AS INT)
FROM v_employee
WHERE
    date_hired BETWEEN @fechaDesde AND @fechaHasta</CommandText>
      </Query>
      <Fields>
        <Field Name="id_employee">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>id_employee</DataField>
        </Field>
        <Field Name="code_national">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>code_national</DataField>
        </Field>
        <Field Name="Apellido_y_nombre">
