  <DataSources>
    <DataSource Name="APS">
      <rd:SecurityType>DataBase</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.81.11.85;Initial Catalog=APS_CAB</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>55d1a3f9-feb6-4185-8b68-2ff9769d7d61</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="SAC">
      <Query>
        <DataSourceName>APS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@desde">
            <Value>=Parameters!desde.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@hasta">
            <Value>=Parameters!hasta.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>declare @fechaDesde datetime = CAST(@desde as DATE);
declare @fechaHasta datetime = DATEADD(SECOND, -1, DATEADD(DAY, 1, CAST(CAST(@hasta AS DATE) AS DATETIME)));

select
                id_period,
	payment_datetime_0 = [temp_payment_datetime_0], 
	[post_date], 
	[enrollment_code], 
	name_regular, 
	employee_code_national, 
	allowance_code, 
	allowance_name, 
	VALUE 
FROM [v_temp_payment] 
WHERE [temp_payment_datetime_0] BETWEEN @fechaDesde AND @fechaHasta
AND [allowance_code] &lt; 80000
AND [allowance_code] NOT IN (18021,18700,/*19201,19203,30000,*/30050,40000)
and id_type_payment = 98632</CommandText>
      </Query>
      <Fields>
        <Field Name="id_period">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>id_period</DataField>
        </Field>
        <Field Name="payment_datetime_0">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>payment_datetime_0</DataField>
        </Field>
        <Field Name="post_date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>post_date</DataField>
        </Field>
        <Field Name="enrollment_code">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>enrollment_code</DataField>
        </Field>
        <Field Name="name_regular">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>name_regular</DataField>
        </Field>
        <Field Name="employee_code_national">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>employee_code_national</DataField>
        </Field>
        <Field Name="allowance_code">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>allowance_code</DataField>
        </Field>
        <Field Name="allowance_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>allowance_name</DataField>
        </Field>
        <Field Name="VALUE">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>VALUE</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
